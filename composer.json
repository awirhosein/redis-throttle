{
    "name": "awirhosein/redis-throttle",
    "authors": [
        {
            "name": "awirhosein",
            "email": "awirhosein@yahoo.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "predis/predis": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "orchestra/testbench": "^10.11"
    },
    "autoload": {
        "psr-4": {
            "Awirhosein\\RedisThrottle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Awirhosein\\RedisThrottle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Awirhosein\\RedisThrottle\\RedisThrottleServiceProvider"
            ]
        }
    },
    "repositories": {
        "packagist": {
            "type": "composer",
            "url": "https://mirror-composer.runflare.com"
        }
    }
}
